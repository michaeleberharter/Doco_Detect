.venv/
# Rechnerabhängige Config-Überschreibungen (z.B. camera.index) – siehe README
config/config.local.yaml
__pycache__/
*.pyc
calibration/*.json
calibration/*.png
# Ohne Schraegstrich: matcht Verzeichnis UND Symlink. In einem Worktree
# zeigen diese Pfade per Symlink auf die echten Daten des Hauptverzeichnisses
# (siehe CLAUDE.md, Abschnitt Worktrees) — mit Schraegstrich waere der
# Symlink untracked und stuende dauerhaft in `git status`.
data/captures
data/reference
data/demo
data/testset-smoke
# reports/ ist Arbeitsordner (ignoriert); reports/archive/ ist das
# VERSIONIERTE Auswertungs-Archiv (analyze --publish). Die Muster-Kombination
# ist Pflicht: Git steigt in komplett ignorierte Ordner nicht ab, erst
# "reports/*" + Ausnahme macht das Archiv trackbar.
reports/*
!reports/archive/
*.sqlite3
.DS_Store

# KI-Segmentierung: Modell-Checkpoints und Download-Reste
models/
*.part

# Sicherungen vor Umbauten (DB, Referenzfotos, Captures) – nie versionieren
backups/

# Korpus-Laufartefakte (der Korpus selbst liegt ausserhalb des Repos)
corpus/runs/

# Aufnahmen, die einen konkreten Fehlerfall festhalten und spaeter als
# Test-Fixture dienen sollen – hier die zwei Reports des 1080p-Vorfalls vom
# 2026-07-22 (Live-Aufloesung != image_width/height aus calibration.json),
# Fixture fuer den noch ausstehenden Aufloesungs-Waechter. Nicht versionieren
# (Bilddaten), aber auch nicht loeschen.
data/quarantine/
