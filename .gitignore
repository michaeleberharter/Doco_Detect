.venv/
# Rechnerabhängige Config-Überschreibungen (z.B. camera.index) – siehe README
config/config.local.yaml
__pycache__/
*.pyc
calibration/*.json
calibration/*.png
data/captures/
data/reference/
data/demo/
data/testset-smoke/
# reports/ ist Arbeitsordner (ignoriert); reports/archive/ ist das
# VERSIONIERTE Auswertungs-Archiv (analyze --publish). Die Muster-Kombination
# ist Pflicht: Git steigt in komplett ignorierte Ordner nicht ab, erst
# "reports/*" + Ausnahme macht das Archiv trackbar.
reports/*
!reports/archive/
*.sqlite3
.DS_Store

# KI-Segmentierung: Modell-Checkpoints und Download-Reste
models/
*.part

# Sicherungen vor Umbauten (DB, Referenzfotos, Captures) – nie versionieren
backups/
